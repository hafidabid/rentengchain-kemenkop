# --- Database ---
DATABASE_URL="postgresql://rantai:rantai@localhost:5433/rantairenteng?schema=public"

# --- App ---
PORT=3001
NODE_ENV=development
# CORS: "*" allows all origins (default). Or a comma-separated allowlist,
# e.g. "https://renteng-chain.talentor.tech".
CORS_ORIGIN="*"

# --- Gemini (EWS screening + Pengurus assistant) ---
# Two auth modes. Prefer Vertex on Google Cloud (no API key — uses ADC):
#   GEMINI_USE_VERTEX="true" + GOOGLE_CLOUD_PROJECT + GOOGLE_CLOUD_LOCATION.
#   Auth: `gcloud auth application-default login` (dev) or a service account in
#   GOOGLE_APPLICATION_CREDENTIALS (server). Otherwise set GEMINI_API_KEY.
GEMINI_USE_VERTEX="false"
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="us-central1"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
# Enable Gemini web/Google-Search grounding for external context (true/false).
ASSISTANT_WEB_GROUNDING="false"
# DB metadata/aggregate snapshot refresh interval (ms).
METADATA_REFRESH_MS="60000"
# Redis for caching the snapshot (optional — in-memory fallback if unset).
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="12h"

# --- On-chain (Base Sepolia, chain 84532) ---
BASE_RPC_URL="https://sepolia.base.org"
EXPLORER_BASE_URL="https://sepolia.basescan.org"
# Relayer (RELAYER_ROLE holder 0xd4427cFd107AdE41763df1D211E7633572dab852) — MUST be
# gas-funded on Base Sepolia. Leave empty to run read-only (writes disabled).
RELAYER_PRIVATE_KEY=""
RELAYER_ADDRESS="0xd4427cFd107AdE41763df1D211E7633572dab852"
# Deployed contract addresses (defaults baked in; override if redeployed).
ADDR_ESCROW="0x199812B240bf8d90dBAfB5C7E2ab79e3fAf728dE"
ADDR_PARTICIPATION="0x1EDf5e51cFc99123cE2e98Ee9cdEA18C072dd48C"
ADDR_LOANPOS="0x49D82FeDEbB676517D0FB8cA3810a0fD1654B650"
RECEIPT_TIMEOUT_MS="15000"
# Per-cooperative secret salt for on-chain member/appeal hashing.
COOP_HASH_SALT="replace-with-per-coop-secret-salt"
# Optional: set to AES-encrypt stored custodial private keys (else stored plain:).
COOP_KEY_ENC_SECRET=""

ADMIN_PRIVATE_KEY=""

# --- Object storage (KTP images): local MinIO defaults; leave blank to disable ---
# For local MinIO (docker compose): keep these. For real AWS: leave S3_ENDPOINT
# EMPTY (writes go to the real S3 API derived from S3_REGION), set
# S3_FORCE_PATH_STYLE="false", real region/bucket/keys, and S3_PUBLIC_URL_BASE to
# a CloudFront domain (e.g. https://xxxx.cloudfront.net) to SERVE images via CDN
# — or leave it blank to derive the S3 virtual-host URL.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="rantai-renteng-ktp"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_FORCE_PATH_STYLE="true"
S3_PUBLIC_URL_BASE="http://localhost:9000/rantai-renteng-ktp"
