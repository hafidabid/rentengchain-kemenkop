# Base URL of the RantaiRenteng NestJS backend (all routes live under /api).
VITE_API_URL=http://localhost:3001

# Demo group used to bootstrap the Anggota group context + loan application.
# Defaults to the seeded "Mekar Wangi Srikandi" group. Anggota routes cannot
# list groups (Pengurus-only endpoint), so the app reads this single group by id.
VITE_DEMO_GROUP_ID=e5f6a7b8-9c0d-41e2-8a4b-5c6d7e8f9a0b
